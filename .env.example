# Database (SQLite for dev; use PostgreSQL URL for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Paystack (get from https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY="sk_test_xxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxx"
PAYSTACK_WEBHOOK_SECRET=""

# Site (optional)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin seed (optional; run: npm run db:seed)
ADMIN_EMAIL="admin@blessingsglobal.org"
ADMIN_PASSWORD="change-me-secure-password"
